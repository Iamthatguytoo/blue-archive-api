modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libxcrypt"]

[agent]
expertMode = true

[workflows]

[[workflows.workflow]]
name = "Run the api"
mode = "sequential"
author = 59678616

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd blue_archive_api && PORT=5000 python blue_archive_characters_api.py"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd blue_archive_api && uvicorn blue_archive_characters_api:server --host 0.0.0.0 --port 5000"]

