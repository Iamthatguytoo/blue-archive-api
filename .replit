modules = ["python-3.11"]
[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libxcrypt"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Run the api"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd blue_archive_api && PORT=5000 python blue_archive_characters_api.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run the api"

[[ports]]
localPort = 5000
externalPort = 80
